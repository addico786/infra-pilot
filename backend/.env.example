#
# InfraPilot backend environment template
# Copy this file to .env and replace placeholder values.
#

# -----------------------------
# Core backend
# -----------------------------
AI_PROVIDER=local

# Local Ollama model (used when AI_PROVIDER=local or no model is provided)
OLLAMA_MODEL=llama3:latest
# Global timeout (seconds) for Ollama requests
OLLAMA_TIMEOUT_SECONDS=360
# Optional model-specific timeout overrides (seconds)
OLLAMA_TIMEOUT_DEEPSEEK_R1_SECONDS=360
OLLAMA_TIMEOUT_WIZARDLM2_SECONDS=300
OLLAMA_TIMEOUT_LLAMA3_SECONDS=180
OLLAMA_TIMEOUT_QWEN2_5_SECONDS=240

# Gemini (optional)
GEMINI_API_KEY=
# Recommended choices: gemini-2.5-flash, gemini-2.5-pro, gemini-pro-latest
GEMINI_MODEL=gemini-2.5-flash

# Oumi (optional)
OUMI_API_KEY=

# Optional: path override for Cline CLI integration
CLINE_PATH=

# -----------------------------
# Optional email notifications
# -----------------------------
# Disabled by default to avoid changing existing behavior.
EMAIL_ENABLED=false

# "From" address used in outgoing email
EMAIL_FROM=your_gmail@gmail.com

# Gmail SMTP (recommended with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
